---
import {
	categoryColorMap,
	containerSizeMap,
	getAstroIconComponent,
	iconSizeMap,
	radiusMap,
	type IconCategory,
	type IconSize,
} from "../utilities/icons";

type Props = {
	category: IconCategory;
	size: IconSize;
};

const { category, size } = Astro.props;

const IconComponent = getAstroIconComponent(category);
---

<div
	title={category}
	class:list={[
		"flex items-center justify-center",
		containerSizeMap[size],
		radiusMap[size],
		categoryColorMap[category],
	]}
>
	<div class="sr-only">{category}</div>
	<IconComponent size={iconSizeMap[size]} />
</div>
