---
import { Image } from "astro:assets";
import { languages } from "../i18n/ui";
import { type Lang } from "../i18n/utilities";

export type Props = {
	id: string;
	href: string;
	title: string;
	description: string;
	image?: {
		src: string | ImageMetadata;
		alt: string;
	};
	publishedAt?: Date;
	lang?: Lang;
};

const { id, href, title, description, image, publishedAt, lang } = Astro.props;
---

<article>
	<a
		href={href}
		aria-labelledby={`${id}-title`}
		aria-describedby={`${id}-description`}
		class="isolate flex h-full w-full flex-col items-center overflow-clip rounded-3xl border border-overlay bg-surface transition hover:border-iris/20 hover:bg-iris/5"
	>
		{
			image && (
				<Image
					src={image.src as any}
					alt={image.alt}
					width={2000}
					height={1200}
					class="h-40 w-full border-b border-b-overlay object-cover"
				/>
			)
		}
		<div class="w-full p-card-gutter">
			<h2
				id={`${id}-title`}
				class="line-clamp-2 text-2xl font-semibold tracking-tight"
			>
				{title}
			</h2>
			<div
				id={`${id}-description`}
				class="mt-2 line-clamp-2 text-subtle sm:mt-1"
			>
				{description}
			</div>
			{
				lang || publishedAt ? (
					<div class="mt-2 flex items-center gap-3">
						{lang ? (
							<div
								title={languages[lang]}
								class="rounded-sm bg-text px-1 py-px font-mono text-[10px] font-semibold text-surface uppercase"
							>
								{lang}
							</div>
						) : (
							""
						)}
						{publishedAt && (
							<div class="text-sm text-muted italic">
								{publishedAt.toLocaleString(lang, {
									dateStyle: "long",
								})}
							</div>
						)}
					</div>
				) : (
					""
				)
			}
		</div>
	</a>
</article>
