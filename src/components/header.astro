---
import BadgeIcon from "../assets/badge.svg";
import SparklesIcon from "../assets/sparkles.svg";
import {
	getLangFromUrl,
	useTranslatedPath,
	useTranslations,
} from "../i18n/utilities";

let lang = getLangFromUrl(Astro.url);
let t = useTranslations(lang);
let translatePath = useTranslatedPath(lang);

let menuItems = [
	{ name: t("nav.themes"), href: translatePath("/themes") },
	{ name: t("nav.palette"), href: translatePath("/palette") },
];
---

<div aria-hidden="true" class="max-w-content relative mx-auto">
	<div
		class="pointer-events-none absolute -top-44 -right-60 -z-10 h-60 w-[36rem] -rotate-12 transform-gpu rounded-full bg-linear-to-r from-gold/50 from-30% via-rose/70 via-70% to-iris blur-3xl md:right-0"
	>
	</div>
</div>

<div class="h-page-top"></div>

<header
	class="wrapper relative flex items-center justify-between gap-3 py-(--card-gutter) [--badge-size:44px] [--card-gutter:var(--spacing-page-gutter-half)] [--card-inner-radius:calc(var(--card-radius)/2)] [--card-radius:1rem]"
>
	<div class="z-50">
		<a
			title={t("nav.home")}
			href={translatePath("/")}
			class="flex items-center gap-3"
		>
			<BadgeIcon class="size-(--badge-size) shrink-0" />
			<span class="font-serif text-xl font-medium tracking-tight italic"
				>Rosé Pine</span
			>
		</a>
	</div>

	<nav aria-label={t("header.nav_label")} class="hidden sm:block">
		<ul class="flex items-center gap-1.5">
			{
				menuItems.map((item) => (
					<li>
						<a
							href={item.href}
							class="inline-block h-8 rounded-lg px-3 leading-8 font-medium transition hover:bg-muted/10"
						>
							{item.name}
						</a>
					</li>
				))
			}
			<li class="pl-3">
				<a
					href={translatePath("/create")}
					class="group/cta flex h-8 shrink-0 items-center gap-2 rounded-lg border border-text pr-4 pl-3 font-serif leading-8 italic transition hover:border-gold hover:bg-gold/10 hover:text-gold"
				>
					<SparklesIcon
						size={16}
						stroke-width="2"
						class="transition-transform group-hover/cta:-rotate-3"
					/>
					<span class="pb-px">{t("nav.create")}</span>
				</a>
			</li>
		</ul>
	</nav>

	<details class="group/menu block select-none sm:hidden">
		<summary
			class="relative z-50 flex size-(--badge-size) items-center justify-center rounded-(--card-inner-radius) transition hover:bg-muted/10 [&::-webkit-details-marker]:hidden"
		>
			<svg
				width="20"
				height="20"
				viewBox="0 0 16 16"
				fill="currentColor"
				xmlns="http://www.w3.org/2000/svg"
			>
				<rect
					x="0"
					y="7.5"
					width="16"
					height="1.5"
					rx="0.5"
					class="origin-center translate-y-[-3.5px] transition-transform duration-150 group-open/menu:translate-y-0 group-open/menu:rotate-45"
				></rect>
				<rect
					x="0"
					y="7.5"
					width="16"
					height="1.5"
					rx="0.5"
					class="origin-center translate-y-[3.5px] transition-transform duration-150 group-open/menu:translate-y-0 group-open/menu:-rotate-45"
				></rect>
			</svg>
		</summary>

		<nav
			aria-label={t("header.nav_label")}
			class="absolute inset-x-(--card-gutter) top-0 z-40 rounded-(--card-radius) bg-surface/80 pt-(--badge-size) shadow-lg shadow-black/10 backdrop-blur-xl backdrop-saturate-150 transition"
		>
			<div class="h-(--card-gutter)"></div>
			<ul class="flex flex-col p-(--card-gutter)">
				{
					menuItems.map((item) => (
						<li>
							<a
								href={item.href}
								class="flex h-14 w-full items-center rounded-(--card-inner-radius) text-xl font-semibold transition-[background-color,padding] hover:bg-muted/10 hover:pl-page-gutter-half"
							>
								{item.name}
							</a>
						</li>
					))
				}
				<li class="w-full pt-3">
					<a
						href={translatePath("/create")}
						class="group/cta flex h-14 shrink-0 items-center justify-center gap-4 rounded-(--card-inner-radius) border border-text pr-5 pl-4 font-serif text-xl italic transition hover:border-gold hover:bg-gold/10 hover:text-gold"
					>
						<SparklesIcon size={24} stroke-width="1.5" />
						<span class="pb-px">{t("nav.create")}</span>
					</a>
				</li>
			</ul>
		</nav>
	</details>
</header>

<style>
	details[open] > *:not(summary) {
		animation: details-show 150ms ease-in-out;
	}

	@keyframes details-show {
		from {
			opacity: 0;
			transform: translateY(0.5rem) scale(0.98);
		}
	}
</style>
