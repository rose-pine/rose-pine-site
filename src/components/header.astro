---
import SparklesIcon from "@lucide/astro/icons/sparkles";
import BadgeIcon from "../assets/badge.svg";
import { getFeaturedRepos, getSortedRepos } from "../data";
import palette from "../data/palette.json";
import {
	getLocaleFromUrl,
	useTranslatedPath,
	useTranslations,
} from "../utilities/i18n";
import CommandMenu from "./command-menu.svelte";

let locale = getLocaleFromUrl(Astro.url);
let t = useTranslations(locale);
let translatePath = useTranslatedPath(locale);

const [sortedRepos, featuredRepos] = await Promise.all([
	getSortedRepos(),
	getFeaturedRepos(),
]);
const repoSlugs = sortedRepos.map((r) => r.slug);

let menuItems = [
	{ name: t("nav.themes"), href: translatePath("/themes") },
	{ name: t("nav.palette"), href: translatePath("/palette") },
];

let searchGroups = [
	{
		heading: t("command.pages"),
		items: [
			{ label: t("nav.home"), href: translatePath("/"), icon: "house" },
			{
				label: t("nav.themes"),
				href: translatePath("/themes"),
				icon: "book-text",
			},
			{
				label: t("nav.palette"),
				href: translatePath("/palette"),
				icon: "palette",
			},
			{
				label: t("nav.create"),
				href: translatePath("/create"),
				icon: "sparkles",
			},
		],
	},
	{
		heading: t("nav.themes"),
		items: sortedRepos.map((repo) => ({
			label: repo.name,
			href: translatePath(`/themes/${repo.slug}`),
			icon: repo.category,
			additionalSearchString: repo.tags.join(" "),
		})),
	},
	{
		heading: t("nav.palette"),
		items: palette.main.map((color) => ({
			label: color.role.charAt(0).toUpperCase() + color.role.slice(1),
			href: translatePath(`/palette/${color.role}`),
			icon: color.role,
		})),
	},
	{
		heading: t("command.community"),
		items: [
			{ label: "Email", href: "mailto:hi@rosepinetheme.com", icon: "mail" },
			{
				label: "Discord",
				href: "https://discord.gg/r6wf35KVJW",
				icon: "discord",
			},
			{ label: "GitHub", href: "https://github.com/rose-pine", icon: "github" },
		],
	},
];

let defaultGroups = [
	searchGroups[0],
	{
		heading: t("command.featured_themes"),
		items: featuredRepos.map((repo) => ({
			label: repo.name,
			href: translatePath(`/themes/${repo.slug}`),
			icon: repo.category,
			additionalSearchString: repo.tags.join(" "),
		})),
	},
	...searchGroups.slice(2),
];
---

<header
	class="relative wrapper mt-page-start flex items-center gap-6 py-(--card-gutters)"
>
	<a
		title={t("nav.home")}
		href={translatePath("/")}
		class="z-50 flex shrink-0 items-center gap-3 rounded-lg"
	>
		<BadgeIcon class="size-(--badge-size) shrink-0" />
		<span class="pe-1 font-serif text-xl font-medium tracking-tight italic"
			>Rosé Pine</span
		>
	</a>

	<div class="flex flex-1 items-center justify-end">
		<CommandMenu
			client:only="svelte"
			{defaultGroups}
			{searchGroups}
			{repoSlugs}
		/>
	</div>

	<div class="z-50 h-7 w-px bg-text/20 md:-me-(--nav-item-space)"></div>

	<nav aria-label={t("header.nav_label")} class="hidden md:block">
		<ul class="flex items-center gap-1.5">
			{
				menuItems.map((item) => (
					<li>
						<a
							href={item.href}
							class="flex h-8 items-center rounded-lg px-(--nav-item-space) font-medium transition hover:bg-muted/10"
						>
							{item.name}
						</a>
					</li>
				))
			}
			<li class="ps-3">
				<a
					href={translatePath("/create")}
					class="group/cta flex h-8 shrink-0 items-center gap-2 rounded-lg border-2 border-text ps-3 pe-4 font-serif font-medium italic transition hover:border-gold hover:bg-gold/10 hover:text-gold"
				>
					<SparklesIcon
						size="16"
						class="transition-transform group-hover/cta:-rotate-3"
					/>
					<span class="pb-px">{t("nav.create")}</span>
				</a>
			</li>
		</ul>
	</nav>

	<details class="group/menu block select-none md:hidden">
		<summary
			class="relative z-50 flex size-(--badge-size) cursor-pointer items-center justify-center rounded-(--card-inner-radius) transition hover:bg-muted/10 [&::-webkit-details-marker]:hidden"
		>
			<svg
				width="20"
				height="20"
				viewBox="0 0 16 16"
				fill="currentColor"
				xmlns="http://www.w3.org/2000/svg"
			>
				<rect
					x="0"
					y="7.5"
					width="16"
					height="1.5"
					rx="0.5"
					class="origin-center translate-y-[-3.5px] transition-transform duration-150 group-open/menu:translate-y-0 group-open/menu:rotate-45"
				></rect>
				<rect
					x="0"
					y="7.5"
					width="16"
					height="1.5"
					rx="0.5"
					class="origin-center translate-y-[3.5px] transition-transform duration-150 group-open/menu:translate-y-0 group-open/menu:-rotate-45"
				></rect>
			</svg>
		</summary>

		<nav
			aria-label={t("header.nav_label")}
			class="absolute inset-x-(--card-gutters) top-0 z-40 rounded-(--card-radius) bg-surface/80 pt-(--badge-size) shadow-lg shadow-black/10 backdrop-blur-xl backdrop-saturate-150 transition"
		>
			<div class="h-(--card-gutters)"></div>
			<ul class="flex flex-col p-(--card-gutters)">
				{
					menuItems.map((item) => (
						<li>
							<a
								aria-label={item.name}
								href={item.href}
								class="flex h-14 w-full items-center rounded-(--card-inner-radius) text-xl font-semibold transition-[background-color,padding] hover:bg-muted/10 hover:ps-(--card-gutters)"
							>
								{item.name}
							</a>
						</li>
					))
				}
				<li class="w-full pt-3">
					<a
						href={translatePath("/create")}
						class="group/cta flex h-14 shrink-0 items-center justify-center gap-4 rounded-(--card-inner-radius) border-2 border-text ps-4 pe-5 font-serif text-xl font-medium italic transition hover:border-gold hover:bg-gold/10 hover:text-gold"
					>
						<SparklesIcon
							size="24"
							class="transition-transform group-hover/cta:-rotate-3"
						/>
						<span class="pb-px">{t("nav.create")}</span>
					</a>
				</li>
			</ul>
		</nav>
	</details>
</header>

<style>
	header {
		--badge-size: 44px;

		--card-gutters: calc(var(--spacing-page-gutters) / 2);
		--card-radius: 1rem;
		--card-inner-radius: calc(var(--card-radius) / 2);

		--nav-item-space: 0.75rem;
	}

	details[open] > *:not(summary) {
		animation: details-show 150ms ease-in-out;
	}

	@keyframes details-show {
		from {
			opacity: 0;
			transform: translateY(0.5rem) scale(0.98);
		}
	}
</style>
