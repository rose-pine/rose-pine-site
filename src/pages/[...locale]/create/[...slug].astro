---
import FlowerIcon from "@lucide/astro/icons/flower";
import { getCollection, getEntry, render } from "astro:content";
import { languages } from "../../../i18n/ui";
import {
	useTranslatedPath,
	useTranslations,
	type Locale,
} from "../../../i18n/utilities";
import Page from "../../../layouts/page.astro";

export async function getStaticPaths() {
	const pages = await getCollection("guides", ({ data }) => {
		return import.meta.env.PROD ? data.draft !== true : true;
	});

	return pages.map((page) => {
		const [locale, ...slug] = page.id.split("/");
		return {
			params: {
				locale: locale === "en" ? undefined : (locale as Locale),
				slug: slug.join("/") || undefined,
			},
			props: { page },
		};
	});
}

const { locale = "en" } = Astro.params;
let t = useTranslations(locale);
let translatePath = useTranslatedPath(locale);

const { page } = Astro.props;
const author = await getEntry(page.data.author);
const { Content } = await render(page);

const slug = page.id.split("/").slice(1).join("/");
const allPages = await getCollection("guides");
const availableLanguages = Object.entries(languages)
	.filter(
		([code]) =>
			code !== locale && allPages.some((page) => page.id === `${code}/${slug}`),
	)
	.map(([code, name]) => ({
		name,
		url: useTranslatedPath(code)(`/create/${slug}`),
	}));

const publishedAt = new Date(page.data.publishedAt).toLocaleDateString(
	[locale, "en"],
	{
		year: "numeric",
		month: "long",
		day: "numeric",
	},
);

const updatedAt = new Date(page.data.updatedAt).toLocaleDateString(
	[locale, "en"],
	{
		year: "numeric",
		month: "long",
		day: "numeric",
	},
);
---

<Page title={page.data.title} description={page.data.description}>
	<div class="wrapper flex flex-col gap-12">
		<div
			class="animate-enter mb-12 flex items-center justify-between gap-3"
			style="--stagger: 1"
		>
			<a
				href={translatePath("/create")}
				class="rounded-full py-1.5 pr-4 pl-3 text-sm font-medium text-subtle transition before:pr-1.5 before:content-['←'] hover:bg-muted/10 hover:text-text"
				>{t("create.title")}</a
			>
		</div>

		<article class="mx-auto w-full max-w-prose">
			<h1
				class="animate-enter mb-4 max-w-2xl text-4xl font-bold tracking-tight text-balance"
				style="--stagger: 1"
			>
				{page.data.title}
			</h1>
			<p
				class="animate-enter mb-8 max-w-md font-serif text-lg text-subtle italic"
				style="--stagger: 2"
			>
				{page.data.description}
			</p>
			<div
				class="animate-enter prose mb-8 prose-headings:text-text prose-p:text-text/90 prose-blockquote:border-iris/50 prose-blockquote:**:text-text/70! prose-strong:text-text/90 prose-em:text-text/90 prose-code:text-text prose-li:text-text/90 prose-li:marker:text-subtle prose-thead:border-muted"
				style="--stagger: 2.5"
			>
				<Content />
			</div>
			{
				author ? (
					<div class="flex flex-wrap items-center gap-1 text-sm font-medium text-nowrap text-subtle italic">
						<span>Authored by </span>
						<a
							href={author.data.url ?? "#!"}
							class="flex items-center gap-1 rounded-lg bg-muted/10 px-2 leading-8 font-medium text-text transition hover:bg-muted/20"
						>
							{author.data.image ? (
								<img
									width="20"
									height="20"
									src={author.data.image}
									alt={author.data.name}
									class="rounded-md border border-muted/10"
								/>
							) : (
								<div class="flex size-5 items-center justify-center rounded-md border border-gold/10 bg-gold/10">
									<FlowerIcon size="16" class="text-gold" />
								</div>
							)}
							{author.data.name}
						</a>
						<span> on</span>
						<time datetime={publishedAt}>{publishedAt}</time>
						{page.data.updatedAt !== page.data.publishedAt && (
							<time
								datetime={updatedAt}
								class="text-sm font-medium text-subtle italic"
							>
								(updated {updatedAt})
							</time>
						)}
					</div>
				) : (
					""
				)
			}

			{
				availableLanguages.length > 0 && (
					<div class="mt-8 border-t border-muted/20 pt-6">
						<div class="flex flex-wrap items-center gap-2 text-sm text-subtle">
							<span class="font-medium">{t("create.also_available_in")}</span>
							{availableLanguages.map((language, index) => (
								<>
									<a
										href={language.url}
										class="rounded-lg bg-muted/10 px-2 py-1 font-medium text-text transition hover:bg-muted/20"
									>
										{language.name}
									</a>
									{index < availableLanguages.length - 1 && (
										<span class="text-subtle/50">•</span>
									)}
								</>
							))}
						</div>
					</div>
				)
			}
		</article>
	</div>
</Page>
