---
import { Image } from "astro:assets";
import { getCollection, type CollectionEntry } from "astro:content";
import IntroSection from "../../../components/intro-section.astro";
import Page from "../../../layouts/page.astro";
import type { Locale } from "../../../types/locale.gen";
import {
	defaultLocale,
	isLocale,
	languages,
	showDefaultLocale,
	useTranslatedPath,
	useTranslations,
	type LocaleParam,
} from "../../../utilities/i18n";
import { objectKeys } from "../../../utilities/object";

export async function getStaticPaths() {
	const guides = await getCollection("guides");
	const showcase = await getCollection("showcase");

	const buildPages = (locale: Locale): CollectionEntry<"guides">[] => {
		const guidesInLocale = guides.filter(
			({ id, data }) =>
				id.startsWith(`${locale}/`) && (!import.meta.env.PROD || !data.draft),
		);

		const existingSlugs = new Set(
			guidesInLocale.map((g) => g.id.split("/").slice(1).join("/")),
		);

		// fill in guides not yet translated with english versions
		const englishFallbacks =
			locale !== defaultLocale
				? guides.filter(
						({ id, data }) =>
							id.startsWith(`${defaultLocale}/`) &&
							(!import.meta.env.PROD || !data.draft) &&
							!existingSlugs.has(id.split("/").slice(1).join("/")),
					)
				: [];

		return [...guidesInLocale, ...englishFallbacks].sort(
			(a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
		);
	};

	const locales: LocaleParam[] = objectKeys(languages);
	if (!showDefaultLocale) locales.push(undefined);

	return locales.map((locale) => ({
		params: { locale },
		props: { pages: buildPages(locale ?? defaultLocale), showcase },
	}));
}

const { locale = defaultLocale } = Astro.params as { locale: LocaleParam };
const { pages, showcase } = Astro.props;
const resolvedLocale = locale ?? defaultLocale;
const t = useTranslations(resolvedLocale);
const translatePath = useTranslatedPath(resolvedLocale);

// pass the guide's own locale so english fallbacks link correctly
const guideHref = (id: string) => {
	const [first, ...rest] = id.split("/");
	return translatePath(
		`/create/${rest.join("/")}`,
		isLocale(first) ? first : defaultLocale,
	);
};
---

<Page title={t("create.title")} description={t("create.description")}>
	<IntroSection
		headline={t("create.title")}
		subheadline={t("create.description")}
	/>

	<section class="animate-enter wrapper" style="--stagger: 3">
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
			<h2 class="col-span-full font-semibold">Guides</h2>
			{
				pages.map((page) => {
					const [first, ...rest] = page.id.split("/");
					const pageLocale = isLocale(first) ? first : defaultLocale;
					const href = guideHref(page.id);
					return (
						<article>
							<a
								href={href}
								aria-labelledby={`${page.id}-title`}
								aria-describedby={`${page.id}-description`}
								class="flex h-full w-full flex-col rounded-(--card-radius) border border-overlay bg-surface transition [--card-gutter:--spacing(5)] [--card-inner-radius:calc(var(--card-radius)/2)] [--card-radius:--spacing(6)] hover:border-iris/20 hover:bg-iris/5"
							>
								<div class="w-full p-(--card-gutter)">
									<h2
										id={`${page.id}-title`}
										class="line-clamp-2 text-lg font-semibold tracking-tight"
									>
										{page.data.title}
									</h2>
									<div
										id={`${page.id}-description`}
										class="mt-1 line-clamp-2 text-subtle"
									>
										{page.data.description}
									</div>
									<div class="mt-2 flex items-center gap-3">
										<div
											title={languages[pageLocale].name}
											class="rounded-sm bg-text px-1 py-px font-mono text-[10px] font-semibold text-surface uppercase"
										>
											{pageLocale}
										</div>
									</div>
								</div>
							</a>
						</article>
					);
				})
			}

			<h2 class="col-span-full mt-page-gutters font-semibold">Showcase</h2>
			{
				showcase.map((site) => (
					<article>
						<a
							href={site.data.url}
							aria-labelledby={`${site.id}-title`}
							aria-describedby={`${site.id}-description`}
							class="group/showcase relative flex h-full w-full flex-col overflow-hidden rounded-(--card-radius) border border-overlay bg-surface transition [--card-gutter:--spacing(5)] [--card-inner-radius:calc(var(--card-radius)/2)] [--card-radius:--spacing(6)]"
						>
							<Image
								src={site.data.image as any}
								alt={site.data.name}
								width={1000}
								height={600}
								class="h-52 w-full rounded-(--card-radius) object-cover object-top"
							/>
							<div class="absolute top-0 bottom-0 flex w-full items-end gap-3 bg-linear-to-t from-main-base p-(--card-gutter) text-main-text transition group-hover/showcase:text-main-iris">
								<h2
									id={`${site.id}-title`}
									class="flex-1 truncate text-sm font-semibold tracking-tight"
								>
									{site.data.name}
								</h2>
								<div id={`${site.id}-description`} class="sr-only">
									{site.data.name}
								</div>
								<div class="shrink-0 text-sm font-semibold tracking-tight">
									&nearr;
								</div>
							</div>
						</a>
					</article>
				))
			}
		</div>
	</section>
</Page>
