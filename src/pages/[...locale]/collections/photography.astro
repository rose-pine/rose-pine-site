---
import { Image } from "astro:assets";
import IntroSection from "../../../components/intro-section.astro";
import { useTranslations, withLocalePaths } from "../../../i18n/utilities";
import Page from "../../../layouts/page.astro";

export async function getStaticPaths() {
	return await withLocalePaths();
}

let { locale = "en" } = Astro.params;
let t = useTranslations(locale);

const baseRawUrl =
	"https://raw.githubusercontent.com/rose-pine/wallpapers/main";
const baseApiUrl = "https://api.github.com/repos/rose-pine/wallpapers/contents";

type GithubFile = { name: string; type: string; download_url: string };

const githubHeaders: HeadersInit = {
	Accept: "application/vnd.github+json",
	...(import.meta.env.GITHUB_TOKEN
		? { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}` }
		: {}),
};

async function getPhotos(folder: string): Promise<GithubFile[]> {
	const res = await fetch(`${baseApiUrl}/${folder}`, {
		headers: githubHeaders,
	});
	if (!res.ok) return [];
	const data: unknown = await res.json();
	if (!Array.isArray(data)) return [];
	return (data as GithubFile[]).filter(
		(f) => f.type === "file" && /\.(jpe?g|png)$/i.test(f.name),
	);
}

const [kainoa, singleCelled] = await Promise.all([
	getPhotos("photography/kainoa-kanter"),
	getPhotos("photography/single-celled"),
]);

const photographs = [
	...kainoa.map((f) => ({
		src: f.download_url,
		href: `${baseRawUrl}/photography/kainoa-kanter/${f.name}`,
		alt: f.name.replace(/[-_]/g, " ").replace(/\.[^.]+$/, ""),
	})),
	...singleCelled.map((f) => ({
		src: f.download_url,
		href: `${baseRawUrl}/photography/single-celled/${f.name}`,
		alt: f.name.replace(/[-_]/g, " ").replace(/\.[^.]+$/, ""),
	})),
];
---

<Page title={t("photography.title")} description={t("photography.description")}>
	<IntroSection
		headline={t("photography.title")}
		subheadline={t("photography.description")}
	/>

	<section class="wrapper animate-enter" style="--stagger: 3">
		<div
			class="grid grid-cols-1 items-center justify-center gap-page-gutter sm:grid-cols-2 lg:grid-cols-3"
		>
			{
				photographs.map(({ src, href, alt }) => (
					<a href={href} target="_blank" rel="noopener noreferrer">
						<Image
							src={src}
							alt={alt}
							width={768}
							height={512}
							class="aspect-3/2 rounded-md object-cover shadow-lg"
						/>
					</a>
				))
			}
		</div>
	</section>
</Page>
