---
import { getCollection, getEntry, render } from "astro:content";
import ColorSwatch from "../../../components/color-swatch.svelte";
import palette from "../../../data/palette.json";
import Page from "../../../layouts/page.astro";
import {
	useTranslatedPath,
	useTranslations,
	withLocalePaths,
} from "../../../utilities/i18n";

export async function getStaticPaths() {
	const colors = await getCollection("palette", ({ id }) =>
		id.startsWith("en/"),
	);
	const entries = colors.map(({ id }) => ({
		params: { color: id.replace("en/", "") },
	}));

	return await withLocalePaths(entries);
}

let { locale = "en", color } = Astro.params;
let t = useTranslations(locale);
let translatePath = useTranslatedPath(locale);

let entry =
	(await getEntry("palette", `${locale}/${color}`)) ??
	(await getEntry("palette", `en/${color}`));
if (!entry) return Astro.redirect("/404");
let { Content } = await render(entry);

const paletteOrder = palette.main.map((c) => c.role);
const allColors = (
	await getCollection("palette", ({ id }) => id.startsWith("en/"))
).sort(
	(a, b) =>
		paletteOrder.indexOf(a.id.replace("en/", "")) -
		paletteOrder.indexOf(b.id.replace("en/", "")),
);
---

<Page
	title={color.charAt(0).toUpperCase() + color.slice(1)}
	description={entry.data.description}
>
	<div class="wrapper">
		<div
			class="animate-enter mb-12 flex items-center justify-between gap-3"
			style="--stagger: 1"
		>
			<a
				href={translatePath("/palette")}
				class="rounded-full py-1.5 ps-3 pe-4 text-sm font-medium text-subtle transition before:pe-1.5 before:content-['←'] hover:bg-muted/10 hover:text-text rtl:before:content-['→']"
				>{t("palette.title")}</a
			>
		</div>

		<div class="flex flex-wrap justify-between gap-12 md:flex-nowrap">
			<article>
				<div>
					<div class="animate-enter mb-8" style="--stagger: 1">
						<ColorSwatch color={color} size="lg" />
					</div>
					<h1
						class="animate-enter mb-4 max-w-2xl text-4xl font-bold tracking-tight text-balance capitalize sm:text-6xl"
						style="--stagger: 1"
					>
						{color}
					</h1>
					<p
						class="animate-enter mb-12 max-w-md font-serif text-xl text-subtle italic"
						style="--stagger: 2"
					>
						{entry.data.description}
					</p>
				</div>
				<div class="animate-enter prose" style="--stagger: 2.5">
					<Content />
				</div>
			</article>

			<aside
				class="flex w-full flex-col gap-8 self-start rounded-xl border border-muted/20 bg-surface px-6 py-5 md:max-w-2xs"
			>
				<div>
					<h2 class="mb-4 font-bold">{t("palette.colours")}</h2>
					<ul role="list" class="flex flex-col gap-2">
						{
							allColors.map(({ id }) => {
								const name = id.replace("en/", "");
								return (
									<li>
										<a
											href={translatePath(`/palette/${name}`)}
											class:list={[
												"inline-flex items-center gap-2 font-medium capitalize",
												name === color
													? "font-serif italic"
													: "font-sans text-subtle transition hover:text-text",
											]}
										>
											<ColorSwatch color={slug} size="sm" />
											{name}
										</a>
									</li>
								);
							})
						}
					</ul>
				</div>
			</aside>
		</div>
	</div>
</Page>
