---
import Layout from "../../layouts/Layout.astro";
import IntroSection from "../../components/intro-section.astro";
import { getLangPaths, useTranslations } from "../../i18n/utilities";

export async function getStaticPaths() {
	return getLangPaths();
}

let { lang = "en" } = Astro.params;
let t = useTranslations(lang);
---

<Layout title={t("create.title")} description={t("create.description")}>
	<IntroSection
		headline={t("create.title")}
		subheadline={t("create.description")}
	/>
</Layout>
