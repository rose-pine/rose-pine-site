---
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import { getLangFromUrl } from "../i18n/utilities";
import "../styles/global.css";

type Props = {
	title: string;
	description: string;
};
let { title, description } = Astro.props;

let lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, viewport-fit=cover"
		/>
		<link rel="icon" href="/favicon.png" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} – Rosé Pine</title>
	</head>
	<body>
		<div class="overflow-hidden">
			<a
				href="#content"
				class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:rounded focus:bg-surface focus:p-1.5 focus:font-medium"
				>Skip to main content</a
			>

			<div aria-hidden="true" class="relative mx-auto">
				<div
					class="pointer-events-none absolute -top-44 -right-60 -z-10 h-60 w-xl -rotate-12 transform-gpu rounded-full bg-linear-to-r from-gold/50 from-30% via-rose/70 via-70% to-iris blur-3xl md:right-0"
				>
				</div>
			</div>

			<div class="grid min-h-dvh grid-rows-[auto_1fr]">
				<div>
					<Header />
				</div>

				<main id="content" class="max-w-screen py-page-top">
					<slot />
				</main>
			</div>

			<Footer />
		</div>
	</body>
</html>
